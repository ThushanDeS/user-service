# Server Configuration
PORT=5004
NODE_ENV=development
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRE=7d

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/user_db
MONGODB_USER=
MONGODB_PASSWORD=

# Other Service URLs
BOOKING_SERVICE_URL=http://localhost:5002

# Loyalty Points Configuration
WELCOME_POINTS=500
POINTS_PER_BOOKING=100
POINTS_PER_DOLLAR=10
BRONZE_THRESHOLD=0
SILVER_THRESHOLD=1000
GOLD_THRESHOLD=5000
PLATINUM_THRESHOLD=10000

# Logging
LOG_LEVEL=info